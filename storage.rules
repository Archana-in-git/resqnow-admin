rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read donor profile pictures
    match /donor_profile_pics/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Prevent direct writes from clients
    }

    // Allow authenticated users to read other public files
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
